<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>فرصتك | منصة التوظيف الذكية</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet"/>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Cairo', sans-serif; background: #f0f4ff; color: #1a1a2e; direction: rtl; }

    /* ===== NAVBAR ===== */
    nav {
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      padding: 14px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 20px rgba(67,97,238,0.1);
    }
    .logo {
      font-size: 26px;
      font-weight: 900;
      background: linear-gradient(135deg, #4361ee, #7209b7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .logo span { color: #f72585; -webkit-text-fill-color: #f72585; }
    .nav-links { display: flex; gap: 20px; align-items: center; }
    .nav-links a {
      text-decoration: none;
      color: #444;
      font-weight: 600;
      font-size: 15px;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #4361ee; }
    .btn-nav {
      background: linear-gradient(135deg, #4361ee, #7209b7);
      color: white !important;
      padding: 10px 24px;
      border-radius: 25px;
      font-weight: 700 !important;
      transition: transform 0.2s, box-shadow 0.2s !important;
      box-shadow: 0 4px 15px rgba(67,97,238,0.3);
    }
    .btn-nav:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(67,97,238,0.4) !important; }

    /* ===== HERO ===== */
    .hero {
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 20px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(67,97,238,0.3) 0%, transparent 70%);
      top: -100px; right: -100px;
      border-radius: 50%;
    }
    .hero::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(247,37,133,0.2) 0%, transparent 70%);
      bottom: -80px; left: -80px;
      border-radius: 50%;
    }
    .hero-content { position: relative; z-index: 2; max-width: 800px; }
    .hero-badge {
      display: inline-block;
      background: rgba(67,97,238,0.2);
      border: 1px solid rgba(67,97,238,0.5);
      color: #a8b8ff;
      padding: 8px 20px;
      border-radius: 20px;
      font-size: 14px;
      margin-bottom: 24px;
      font-weight: 600;
    }
    .hero h1 {
      font-size: 58px;
      font-weight: 900;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .hero h1 .highlight {
      background: linear-gradient(135deg, #4361ee, #f72585);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p {
      font-size: 20px;
      color: #b0b8d8;
      max-width: 580px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }
    .hero-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: linear-gradient(135deg, #4361ee, #7209b7);
      color: white;
      padding: 16px 36px;
      border-radius: 30px;
      font-size: 17px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 8px 30px rgba(67,97,238,0.4);
      transition: all 0.3s;
    }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(67,97,238,0.5); }
    .btn-secondary {
      background: rgba(255,255,255,0.1);
      color: white;
      padding: 16px 36px;
      border-radius: 30px;
      font-size: 17px;
      font-weight: 700;
      border: 1px solid rgba(255,255,255,0.3);
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.2); transform: translateY(-3px); }

    /* Stats bar */
    .stats-bar {
      background: rgba(255,255,255,0.05);
      border-top: 1px solid rgba(255,255,255,0.1);
      padding: 24px 40px;
      display: flex;
      justify-content: center;
      gap: 60px;
      flex-wrap: wrap;
    }
    .stat-item { text-align: center; }
    .stat-number { font-size: 28px; font-weight: 900; color: #fff; }
    .stat-label { font-size: 13px; color: #8892b8; margin-top: 4px; }

    /* ===== FEATURES ===== */
    .features {
      padding: 80px 40px;
      background: #fff;
    }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-tag {
      display: inline-block;
      background: #eff3ff;
      color: #4361ee;
      padding: 6px 18px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .section-header h2 { font-size: 38px; font-weight: 900; color: #1a1a2e; }
    .section-header p { color: #666; font-size: 17px; margin-top: 10px; }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
      max-width: 1100px;
      margin: 0 auto;
    }
    .feature-card {
      background: #f8faff;
      border-radius: 20px;
      padding: 36px 28px;
      border: 1px solid #e8eeff;
      transition: all 0.3s;
      cursor: pointer;
    }
    .feature-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(67,97,238,0.12);
      border-color: #4361ee;
    }
    .feature-icon {
      width: 60px; height: 60px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      margin-bottom: 20px;
    }
    .feature-card h3 { font-size: 19px; font-weight: 700; margin-bottom: 10px; color: #1a1a2e; }
    .feature-card p { color: #666; font-size: 15px; line-height: 1.7; }

    /* ===== HOW IT WORKS ===== */
    .how-it-works {
      background: linear-gradient(135deg, #f0f4ff, #fdf0ff);
      padding: 80px 40px;
    }
    .steps-container {
      display: flex;
      justify-content: center;
      gap: 0;
      max-width: 1000px;
      margin: 0 auto;
      position: relative;
      flex-wrap: wrap;
    }
    .step-line {
      position: absolute;
      top: 45px;
      right: 16%;
      left: 16%;
      height: 3px;
      background: linear-gradient(90deg, #4361ee, #7209b7, #f72585);
      z-index: 0;
    }
    .step {
      text-align: center;
      flex: 1;
      min-width: 180px;
      position: relative;
      z-index: 1;
      padding: 0 16px;
    }
    .step-number {
      width: 60px; height: 60px;
      border-radius: 50%;
      background: linear-gradient(135deg, #4361ee, #7209b7);
      color: white;
      font-size: 22px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      box-shadow: 0 8px 25px rgba(67,97,238,0.4);
    }
    .step h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
    .step p { font-size: 13px; color: #666; }

    /* ===== PRICING ===== */
    .pricing {
      padding: 80px 40px;
      background: #fff;
    }
    .pricing-cards {
      display: flex;
      justify-content: center;
      gap: 24px;
      max-width: 900px;
      margin: 0 auto;
      flex-wrap: wrap;
    }
    .price-card {
      background: #f8faff;
      border-radius: 24px;
      padding: 40px 32px;
      flex: 1;
      min-width: 260px;
      max-width: 360px;
      border: 2px solid #e8eeff;
      text-align: center;
      position: relative;
    }
    .price-card.featured {
      background: linear-gradient(135deg, #4361ee, #7209b7);
      border-color: transparent;
      transform: scale(1.05);
      box-shadow: 0 20px 60px rgba(67,97,238,0.35);
    }
    .price-card.featured * { color: white !important; }
    .popular-badge {
      background: #f72585;
      color: white;
      padding: 4px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
    }
    .price-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 10px; }
    .price-amount { font-size: 42px; font-weight: 900; color: #4361ee; margin: 16px 0 8px; }
    .price-period { font-size: 14px; color: #888; margin-bottom: 24px; }
    .price-features { list-style: none; text-align: right; margin-bottom: 30px; }
    .price-features li {
      padding: 8px 0;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .price-features li::before { content: '✓'; color: #4caf50; font-weight: 700; }
    .price-card.featured .price-features li::before { color: #a8ffb8; }
    .btn-plan {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      border: none;
      font-family: 'Cairo', sans-serif;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
    }
    .btn-free { background: #eff3ff; color: #4361ee; }
    .btn-paid { background: white; color: #4361ee; }
    .btn-plan:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }

    /* ===== CTA SECTION ===== */
    .cta-section {
      background: linear-gradient(135deg, #0f0c29, #302b63);
      padding: 80px 40px;
      text-align: center;
    }
    .cta-section h2 { font-size: 40px; font-weight: 900; color: white; margin-bottom: 16px; }
    .cta-section p { color: #b0b8d8; font-size: 18px; margin-bottom: 36px; }

    /* ===== FOOTER ===== */
    footer {
      background: #0a0a1a;
      padding: 40px;
      text-align: center;
      color: #555;
      font-size: 14px;
    }
    footer .logo { display: block; font-size: 22px; margin-bottom: 16px; }

    /* Floating particles */
    .particle {
      position: absolute;
      border-radius: 50%;
      animation: float 6s infinite ease-in-out;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); opacity: 0.7; }
      50% { transform: translateY(-20px) rotate(180deg); opacity: 1; }
    }

    /* Scroll animation */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate { animation: fadeUp 0.6s ease forwards; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav>
  <div class="logo">فرصتك<span>.</span></div>
  <div class="nav-links">
    <a href="#">الخدمات</a>
    <a href="#">كيف يعمل</a>
    <a href="#">الأسعار</a>
    <a href="register.html" class="btn-nav">ابدأ مجاناً 🚀</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="particle" style="width:12px;height:12px;background:#4361ee;top:20%;right:10%;animation-delay:0s;"></div>
  <div class="particle" style="width:8px;height:8px;background:#f72585;top:60%;right:80%;animation-delay:2s;"></div>
  <div class="particle" style="width:10px;height:10px;background:#7209b7;top:80%;right:30%;animation-delay:4s;"></div>

