  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <h2>وظيفتك تنتظرك 🎯</h2>
  <p>انضم لآلاف الجزائريين الذين يستخدمون فرصتك للحصول على وظائفهم</p>
  <a href="register.html" class="btn-primary" style="display:inline-flex;font-size:18px;padding:18px 44px;">
